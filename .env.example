# CardioShield Backend – Environment Configuration
# Copy this file to .env and set your values.

# REQUIRED: Secret key used to derive the AES-256 encryption key.
# Must be set for production. If not set, a random key is used (data won't survive restarts).
CARDIOSHIELD_SECRET_KEY=your-strong-secret-key-here

# API Key for authenticating requests to the backend.
# If not set, a random key is auto-generated and printed at startup.
CARDIOSHIELD_API_KEY=your-api-key-here

# OPTIONAL: Server settings
CARDIOSHIELD_HOST=0.0.0.0
CARDIOSHIELD_PORT=5555
CARDIOSHIELD_DEBUG=false
CARDIOSHIELD_CORS_ORIGIN=*

# OPTIONAL: Backend URL (used by Streamlit frontend)
CARDIOSHIELD_BACKEND_URL=http://localhost:5555
